<h3>Criação de conta</h3>

{{#if error}}
<div class="alert alert-danger" role="alert">
    {{error}}
</div>
{{/if}}

<form class="row g-3" action="/signup" method="post">
    <div class="col-md-8">
        <label for="name" class="form-label">Nome Completo</label>
        <input type="text" class="form-control" id="name" name="name" maxlength="100" value="{{user.name}}" required>
    </div>

    <div class="col-md-8">
        <label for="email" class="form-label">Email</label>
        <input type="email" class="form-control" id="email" name="email" maxlength="100" value="{{user.email}}" required>
    </div>

    <div class="col-md-8">
        <label for="password" class="form-label">Senha</label>
        <input type="password" class="form-control" id="password" name="password" maxlength="100" required>
    </div>

    <div class="col-md-8">
        <label for="confirmPassword" class="form-label">Repetir senha</label>
        <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" maxlength="100" required>
    </div>

    <div class="col-md-8">
        <label for="majorId" class="form-label">Curso</label>
        <select class="form-select" id="majorId" name="majorId" required>
            <option value="">Selecione um curso</option>
            {{#each majors}}
            <option value="{{id}}">{{code}} - {{name}}</option>
            {{/each}}
        </select>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary" {{#unless hasMajors}}disabled{{/unless}}>Criar conta</button>
        <a href="/login" class="btn btn-secondary">Cancelar</a>
    </div>
</form>

{{#unless hasMajors}}
<p class="text-muted mt-3">Cadastre um curso antes de criar usuários.</p>
{{/unless}}
