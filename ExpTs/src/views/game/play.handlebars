<div id="tela-menu" class="tela ativa">
    <div class="menu-conteudo">
        <img src="assets/images/logo.png" alt="Beat Slay Repeat" class="logo-jogo">

        <div class="dificuldade-selecao">
            <p class="dificuldade-titulo">Dificuldade</p>
            <div class="dificuldade-opcoes">
                <label class="dificuldade-opcao">
                    <input type="radio" name="dificuldade" value="easy">
                    <span>Fácil</span>
                </label>
                <label class="dificuldade-opcao">
                    <input type="radio" name="dificuldade" value="medium" checked>
                    <span>Médio</span>
                </label>
                <label class="dificuldade-opcao">
                    <input type="radio" name="dificuldade" value="hard">
                    <span>Difícil</span>
                </label>
            </div>
        </div>

        <button id="btn-iniciar" type="button" class="btn-primario">JOGAR</button>
        <button id="btn-como-jogar" type="button" class="btn-secundario">COMO JOGAR</button>

        <p class="recorde-menu">Melhor: <span id="menu-melhor-score">0</span></p>
    </div>
</div>

<div id="tela-jogo" class="tela oculta">
    <div id="hud">
        <div class="hud-item">
            <span class="hud-rotulo">SCORE</span>
            <span id="hud-score">0</span>
        </div>
        <div class="hud-item">
            <span class="hud-rotulo">COMBO</span>
            <span id="hud-combo">x0</span>
        </div>
        <div class="hud-item">
            <span class="hud-rotulo">VIDAS</span>
            <div id="hud-reputacao"></div>
        </div>
        <div class="hud-item">
            <span class="hud-rotulo">PRECISÃO</span>
            <span id="hud-accuracy">100%</span>
        </div>
        <button id="btn-pausar" type="button" class="btn-pausar" aria-label="Pausar jogo">⏸</button>
    </div>

    <div id="area-jogo">
        <div class="faixa" id="faixa-0" data-lane="0"></div>
        <div class="faixa" id="faixa-1" data-lane="1"></div>
        <div class="faixa" id="faixa-2" data-lane="2"></div>
        <div class="faixa" id="faixa-3" data-lane="3"></div>

        <div id="sprite-baterista"></div>
        <div id="sprite-personagem"></div>
        <div id="sprite-guitarrista"></div>

        <div id="zona-acerto"></div>

        <div class="zona-tecla" id="zona-tecla-0" data-lane="0">←</div>
        <div class="zona-tecla" id="zona-tecla-1" data-lane="1">↓</div>
        <div class="zona-tecla" id="zona-tecla-2" data-lane="2">↑</div>
        <div class="zona-tecla" id="zona-tecla-3" data-lane="3">→</div>
    </div>

    <div id="feedback-acerto" aria-live="assertive" aria-atomic="true"></div>
    <div id="countdown" aria-live="assertive" aria-atomic="true"></div>
</div>

<div id="tela-pausa" class="tela oculta">
    <div class="pausa-conteudo">
        <h2>PAUSADO</h2>
        <button id="btn-retomar" type="button" class="btn-primario">Continuar</button>
        <button id="btn-sair-pausa" type="button" class="btn-secundario">Sair</button>
    </div>
</div>

<div id="tela-tutorial" class="tela oculta">
    <div class="tutorial-conteudo">
        <h2>COMO JOGAR</h2>
        <ul class="tutorial-lista">
            <li>Use as setas ← ↓ ↑ → quando as notas chegarem na linha de acerto.</li>
            <li>Mantenha o combo para multiplicar os pontos.</li>
            <li>Se errar ou perder notas, voce perde coracoes.</li>
            <li>Pegue notas de power-up para ganhar multiplicador temporario.</li>
        </ul>
        <button id="btn-voltar-tutorial" type="button" class="btn-primario">VOLTAR</button>
    </div>
</div>

<div id="tela-game-over" class="tela oculta">
    <div class="game-over-conteudo">
        <h2 class="game-over-titulo">FIM DE SHOW</h2>
        <div class="game-over-stats">
            <div class="stat-item">
                <span class="stat-rotulo">Pontuação</span>
                <span id="game-over-score" class="stat-valor">0</span>
            </div>
            <div class="stat-item">
                <span class="stat-rotulo">Precisão</span>
                <span id="game-over-accuracy" class="stat-valor">100%</span>
            </div>
            <div class="stat-item">
                <span class="stat-rotulo">Recorde</span>
                <span id="game-over-recorde" class="stat-valor">0</span>
            </div>
        </div>
        <button id="btn-tentar-novamente" type="button" class="btn-primario">TENTAR NOVAMENTE</button>
        <button id="btn-menu-principal" type="button" class="btn-secundario">Menu Principal</button>
    </div>
</div>

<script src="js/storage.js"></script>
<script src="js/audio.js"></script>
<script src="js/collision.js"></script>
<script src="js/input.js"></script>
<script src="js/beatmap.js"></script>
<script src="js/notes.js"></script>
<script src="js/ui.js"></script>
<script src="js/game.js"></script>
<script src="js/main.js"></script>
