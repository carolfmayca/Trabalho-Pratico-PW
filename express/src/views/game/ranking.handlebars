<section>
    <h2 class="mb-4">🏆 Ranking — Top 10</h2>

    {{#if hasEntries}}
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th scope="col" class="text-center" style="width: 80px;">#</th>
                <th scope="col">Jogador</th>
                <th scope="col" class="text-end" style="width: 160px;">Pontuação</th>
            </tr>
        </thead>
        <tbody>
            {{#each entries}}
            <tr>
                <td class="text-center fw-bold">{{position}}</td>
                <td>{{name}}</td>
                <td class="text-end fw-bold">{{score}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{else}}
    <p class="text-muted">Nenhuma partida registrada ainda. Seja o primeiro a jogar!</p>
    {{/if}}

    <a href="/" class="btn btn-primary mt-2">Jogar agora</a>
</section>
